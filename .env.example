# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# For Development: Set USE_SQLITE=True (SQLite, no external dependencies)
# For Production: Set USE_SQLITE=False (MySQL with PyMySQL)
USE_SQLITE=True
DB_NAME=credhand_db
DB_USER=root
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=3306

# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback/

# UPI Payment Gateway (Razorpay or PhonePe)
UPI_GATEWAY=razorpay
UPI_KEY_ID=your-upi-key-id
UPI_KEY_SECRET=your-upi-key-secret

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Frontend URL
FRONTEND_URL=http://localhost:8000
